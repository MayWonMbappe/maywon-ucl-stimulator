{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "maywon-ucl-stimulator",
  "main": "./src/index.js",
  "compatibility_date": "2026-06-20",
  "workers_dev": true,
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "none"
  }
}
